# Files excluded from a distributable theme .zip.
# Build-time and development artefacts only — never user-facing theme code.
# `colophon new` copies this into every generated theme so the line ships clean.
#
# NOTE: inc/github-updater.php is intentionally NOT listed here.
# It is excluded from WP.org builds only — GitHub release builds include it.
# package-theme.sh handles this distinction via --wporg / --github flags.
/.distignore
/.git
/.github
/.gitignore
/node_modules
/vendor
/colophon
/colophon.json
/colophon.manifest.json
/ARCHITECTURE.md
/DESIGN-UPLIFT.md
/PILLARS.md
/README.md
/GUIDE.md
/THEME-CHECK.md
/tools
/composer.json
/composer.lock
/phpcs.xml.dist
/phpstan.neon
/package.json
/package-lock.json
*.zip

