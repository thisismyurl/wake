{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"_comment_architecture": "[CORE structure] The top-level keys, the settings shape, and the templateParts/customTemplates skeleton are the portable scaffold every theme in the line keeps. [SKIN values] The palette, fontFamilies, fontSizes, spacing values, and the whole styles block are design — re-authored per theme. Colophon's own skin is a warm literary design (EB Garamond + Spectral, ink-on-paper palette). The CLI does not auto-merge this file; `colophon doctor` reports drift in the core-owned settings keys instead.",
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"_comment": "[SKIN] Warm literary palette — ink-on-paper, one library-cloth teal accent. All text/background pairs clear WCAG AA. defaultPalette off so the editor offers only the theme's tokens.",
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{ "slug": "ink",         "color": "#1c1917", "name": "Ink" },
				{ "slug": "ink-soft",    "color": "#433e3b", "name": "Ink Soft" },
				{ "slug": "ink-muted",   "color": "#6b6460", "name": "Ink Muted" },
				{ "slug": "ink-deep",    "color": "#0f0d0c", "name": "Ink Deep" },
				{ "slug": "line",        "color": "#dedad3", "name": "Hairline" },
				{ "slug": "accent",      "color": "#3d6b5e", "name": "Accent" },
				{ "slug": "accent-soft", "color": "#e8f0ed", "name": "Accent Soft" },
				{ "slug": "paper-soft",  "color": "#f2f0eb", "name": "Paper Soft" },
				{ "slug": "paper",       "color": "#faf9f6", "name": "Paper" }
			]
		},
		"typography": {
			"_comment": "[SKIN] EB Garamond (headings/display) and Spectral (body/reading) — both SIL OFL 1.1, self-hosted under assets/fonts/. System stacks kept as fallbacks; the starter inherits them until a re-skin swaps them out.",
			"fluid": true,
			"customFontSize": false,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"textDecoration": true,
			"fontFamilies": [
				{
					"name": "EB Garamond",
					"slug": "eb-garamond",
					"fontFamily": "'EB Garamond', Georgia, 'Times New Roman', Times, serif",
					"fontFace": [
						{
							"fontFamily": "EB Garamond",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/eb-garamond/eb-garamond-normal-latin-ext.woff2", "file:./assets/fonts/eb-garamond/eb-garamond-normal.woff2" ]
						},
						{
							"fontFamily": "EB Garamond",
							"fontWeight": "400 500",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/eb-garamond/eb-garamond-italic-latin-ext.woff2", "file:./assets/fonts/eb-garamond/eb-garamond-italic.woff2" ]
						}
					]
				},
				{
					"name": "Spectral",
					"slug": "spectral",
					"fontFamily": "'Spectral', Georgia, 'Times New Roman', Times, serif",
					"fontFace": [
						{
							"fontFamily": "Spectral",
							"fontWeight": "300",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-300-latin-ext.woff2", "file:./assets/fonts/spectral/spectral-300.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-400-latin-ext.woff2", "file:./assets/fonts/spectral/spectral-400.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontWeight": "400",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-400-italic-latin-ext.woff2", "file:./assets/fonts/spectral/spectral-400-italic.woff2" ]
						},
						{
							"fontFamily": "Spectral",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/spectral/spectral-600-latin-ext.woff2", "file:./assets/fonts/spectral/spectral-600.woff2" ]
						}
					]
				},
				{
					"name": "Serif",
					"slug": "serif",
					"fontFamily": "Georgia, 'Times New Roman', Times, serif"
				},
				{
					"name": "Sans",
					"slug": "sans",
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"name": "Mono",
					"slug": "mono",
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
				}
			],
			"fontSizes": [
				{ "name": "X-Small",  "slug": "xs",      "size": "0.75rem",                                                                    "fluid": false },
				{ "name": "Small",    "slug": "sm",      "size": "clamp(0.875rem, 0.85rem + 0.12vw, 0.9375rem)",  "fluid": { "min": "0.875rem",  "max": "0.9375rem" } },
				{ "name": "Base",     "slug": "base",    "size": "clamp(1.0625rem, 1rem + 0.25vw, 1.125rem)",      "fluid": { "min": "1.0625rem", "max": "1.125rem" } },
				{ "name": "Medium",   "slug": "md",      "size": "clamp(1.2rem, 1.1rem + 0.4vw, 1.45rem)",         "fluid": { "min": "1.2rem",    "max": "1.45rem" } },
				{ "name": "Large",    "slug": "lg",      "size": "clamp(1.5rem, 1.3rem + 0.9vw, 2rem)",            "fluid": { "min": "1.5rem",    "max": "2rem" } },
				{ "name": "X-Large",  "slug": "xl",      "size": "clamp(2rem, 1.6rem + 1.8vw, 3rem)",              "fluid": { "min": "2rem",      "max": "3rem" } },
				{ "name": "2X-Large", "slug": "2xl",     "size": "clamp(2.5rem, 1.9rem + 3vw, 4.5rem)",            "fluid": { "min": "2.5rem",    "max": "4.5rem" } },
				{ "name": "3X-Large", "slug": "3xl",     "size": "clamp(3rem, 2.2rem + 4vw, 5rem)",                "fluid": { "min": "3rem",      "max": "5rem" } },
				{ "name": "Display",  "slug": "display", "size": "clamp(3rem, 1.8rem + 6vw, 7rem)",                "fluid": { "min": "3rem",      "max": "7rem" } }
			]
		},
		"spacing": {
			"_comment": "[CORE structure / SKIN values] A linear step scale.",
			"customSpacingSize": false,
			"spacingSizes": [
				{ "name": "1",  "slug": "1",  "size": "0.25rem" },
				{ "name": "2",  "slug": "2",  "size": "0.5rem" },
				{ "name": "3",  "slug": "3",  "size": "0.75rem" },
				{ "name": "4",  "slug": "4",  "size": "1rem" },
				{ "name": "5",  "slug": "5",  "size": "1.5rem" },
				{ "name": "6",  "slug": "6",  "size": "2rem" },
				{ "name": "8",  "slug": "8",  "size": "2.5rem" },
				{ "name": "10", "slug": "10", "size": "3rem" },
				{ "name": "12", "slug": "12", "size": "4rem" },
				{ "name": "16", "slug": "16", "size": "6rem" },
				{ "name": "20", "slug": "20", "size": "8rem" }
			]
		},
		"layout": {
			"_comment": "[CORE structure / SKIN values] contentSize = reading measure; wideSize = the band width.",
			"contentSize": "720px",
			"wideSize": "1100px"
		},
		"border": { "color": true, "radius": true, "style": true, "width": true },
		"dimensions": { "minHeight": true, "aspectRatio": true },
		"position": { "sticky": true },
		"blocks": {
			"core/button": { "border": { "radius": false } },
			"core/post-featured-image": { "allowResize": false }
		}
	},
	"styles": {
		"_comment": "[SKIN] Warm literary design. EB Garamond for headings, Spectral for body — ink-on-paper palette. A theme built on Colophon replaces this whole block.",
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--spectral)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.72"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--6)",
			"padding": {
				"left": "var(--wp--preset--spacing--5)",
				"right": "var(--wp--preset--spacing--5)"
			}
		},
		"elements": {
			"h1": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--2xl)", "fontWeight": "700", "lineHeight": "1.12", "letterSpacing": "-0.02em", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink-deep)" }
			},
			"h2": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--xl)", "fontWeight": "700", "lineHeight": "1.2", "letterSpacing": "-0.015em", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h3": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--lg)", "fontWeight": "500", "lineHeight": "1.3", "letterSpacing": "-0.01em", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h4": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--md)", "fontWeight": "500", "lineHeight": "1.35", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h5": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600", "lineHeight": "1.4", "letterSpacing": "0.04em", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink-soft)" }
			},
			"h6": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--xs)", "fontWeight": "600", "lineHeight": "1.5", "letterSpacing": "0.06em", "fontStyle": "normal" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				"typography": { "textDecoration": "underline" },
				":hover": { "color": { "text": "var(--wp--preset--color--ink)" } },
				":focus": { "color": { "text": "var(--wp--preset--color--ink)" } }
			},
			"button": {
				"color": { "background": "var(--wp--preset--color--ink)", "text": "var(--wp--preset--color--paper)" },
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "400", "letterSpacing": "0.03em" },
				"border": { "radius": "2px" },
				"spacing": { "padding": { "top": "var(--wp--preset--spacing--2)", "bottom": "var(--wp--preset--spacing--2)", "left": "var(--wp--preset--spacing--4)", "right": "var(--wp--preset--spacing--4)" } },
				":hover": { "color": { "background": "var(--wp--preset--color--accent)", "text": "var(--wp--preset--color--paper)" } },
				":focus": { "color": { "background": "var(--wp--preset--color--accent)", "text": "var(--wp--preset--color--paper)" } }
			}
		},
		"blocks": {
			"core/paragraph": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--base)", "lineHeight": "1.72" }
			},
			"core/pullquote": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--lg)", "fontStyle": "italic", "lineHeight": "1.5" },
				"color": { "text": "var(--wp--preset--color--ink)", "background": "transparent" }
			},
			"core/quote": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--md)", "fontStyle": "italic", "lineHeight": "1.6" },
				"color": { "text": "var(--wp--preset--color--ink-soft)" },
				"spacing": { "padding": { "left": "var(--wp--preset--spacing--5)" } }
			},
			"core/code": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--mono)", "fontSize": "var(--wp--preset--font-size--sm)", "lineHeight": "1.6" },
				"color": { "background": "var(--wp--preset--color--paper-soft)", "text": "var(--wp--preset--color--ink)" }
			},
			"core/post-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontWeight": "700", "lineHeight": "1.12", "letterSpacing": "-0.02em", "textDecoration": "none" },
				"color": { "text": "var(--wp--preset--color--ink-deep)" }
			},
			"core/post-excerpt": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--base)", "lineHeight": "1.7" },
				"color": { "text": "var(--wp--preset--color--ink-soft)" }
			},
			"core/post-date": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"core/post-terms": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "600", "letterSpacing": "0.08em", "textTransform": "uppercase" },
				"color": { "text": "var(--wp--preset--color--accent)" }
			},
			"core/site-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--eb-garamond)", "fontSize": "var(--wp--preset--font-size--lg)", "fontWeight": "700", "textDecoration": "none" },
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"core/site-tagline": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)", "letterSpacing": "0.06em", "textTransform": "uppercase" },
				"color": { "text": "var(--wp--preset--color--ink-muted)" }
			},
			"core/navigation": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--spectral)", "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "400", "letterSpacing": "0.04em" }
			},
			"core/separator": {
				"color": { "text": "var(--wp--preset--color--line)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": []
}
